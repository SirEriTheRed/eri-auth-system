{
  "entry": [
    "src/index.ts"
  ],
  "project": [
    "**/*.ts"
  ],
  "ignoreDependencies": [
    "@vitest/ui",
    "@semantic-release/npm",
    "@semantic-release/changelog",
    "@semantic-release/git",
    "globals",
    "typedoc-plugin-markdown"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "exports": "error"
  }
}
