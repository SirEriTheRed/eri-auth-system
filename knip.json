{
  "entry": [
    "src/index.ts"
  ],
  "project": [
    "src/**/*.ts"
  ],
  "ignore": [
    "tests/**/*.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ],
  "ignoreDependencies": [
    "@vitest/ui"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "exports": "error"
  }
}
