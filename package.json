{
  "name": "@EriTheRed/eri-auth-system",
  "version": "0.0.1",
  "type": "module",
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "EriTheRed",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "analyze": "knip && npx depcheck --ignores=eslint-config-prettier,knip,depcheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "lint:spell": "cspell lint \"**/*.{ts,md,json}\" --no-progress",
    "check:pack": "publint --strict && attw --pack",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "peerDependencies": {
    "@fastify/cookie": ">=9.0.0",
    "@fastify/jwt": ">=8.0.0",
    "@sinclair/typebox": "^0.32.0",
    "fastify": ">=4.0.0"
  },
  "dependencies": {
    "argon2": "^0.31.0",
    "fastify-plugin": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^20.19.42",
    "@vitest/coverage-v8": "^4.1.8",
    "cspell": "^10.0.1",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^65.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.5",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
